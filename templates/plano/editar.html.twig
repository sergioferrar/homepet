{% extends 'base.html.twig' %}

{% block page_title %}Editar Plano{% endblock %}

{% block body %}
<div class="pagetitle">
    <h1>Editar plano: <span class="text-primary">{{ plano.titulo }}</span></h1>
    <a class="btn btn-outline-secondary btn-sm mb-3" href="{{ url('app_plano') }}">
        <i class="bi bi-arrow-left me-1"></i>Voltar
    </a>
    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ url('home') }}">Home</a></li>
            <li class="breadcrumb-item">Configurações</li>
            <li class="breadcrumb-item"><a href="{{ url('app_plano') }}">Planos</a></li>
            <li class="breadcrumb-item active">Editar</li>
        </ol>
    </nav>
</div>

<form method="post" action="{{ url('app_plano_update', {'id': plano.id}) }}">
<section class="section">
    <div class="row">

        {# ── Coluna esquerda: módulos ───────────────────────────────── #}
        <div class="col-lg-8 col-sm-12">

            {# Módulos padrão #}
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-primary text-white">
                    <h6 class="mb-0">
                        <i class="bi bi-check2-all me-2"></i>Módulos padrão
                        <small class="opacity-75 ms-1">— incluídos em todos os planos</small>
                    </h6>
                </div>
                <ul class="list-group list-group-flush">
                    {% for modulo in modulosPadrao %}
                        <li class="list-group-item d-flex align-items-center gap-2">
                            <span class="text-success"><i class="bi bi-check-circle-fill"></i></span>
                            {{ modulo.titulo }}
                            <span class="badge bg-light text-dark border ms-auto small">Padrão</span>
                        </li>
                    {% endfor %}
                </ul>
            </div>

            {# Módulos adicionais #}
            <div class="card shadow-sm border-0">
                <div class="card-header bg-warning text-dark">
                    <h6 class="mb-0">
                        <i class="bi bi-star me-2"></i>Módulos adicionais
                        <small class="opacity-75 ms-1">— cobrados à parte (fiscal / PDV)</small>
                    </h6>
                </div>
                <ul class="list-group list-group-flush">
                    {% for modulo in modulosAdicionais %}
                        {% set isAtivo = modulo.id in idsAtivos %}
                        <li class="list-group-item {{ isAtivo ? 'list-group-item-warning' : '' }}">
                            <div class="form-check">
                                <input
                                    class="form-check-input modulo-check"
                                    type="checkbox"
                                    name="modulos[]"
                                    id="mod_{{ modulo.id }}"
                                    value="{{ modulo.id }}"
                                    {{ isAtivo ? 'checked' : '' }}>
                                <label class="form-check-label d-flex align-items-center gap-2" for="mod_{{ modulo.id }}">
                                    <span class="text-warning"><i class="bi bi-star"></i></span>
                                    {{ modulo.titulo }}
                                    {% if isAtivo %}
                                        <span class="badge bg-success ms-auto">Ativo neste plano</span>
                                    {% else %}
                                        <span class="badge bg-secondary ms-auto">Não incluído</span>
                                    {% endif %}
                                </label>
                            </div>
                        </li>
                    {% else %}
                        <li class="list-group-item text-muted small">Nenhum módulo adicional disponível.</li>
                    {% endfor %}
                </ul>
            </div>
        </div>

        {# ── Coluna direita: dados ─────────────────────────────────── #}
        <div class="col-lg-4 col-sm-12 mt-4 mt-lg-0">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-light">
                    <h6 class="mb-0">Dados do plano</h6>
                </div>
                <div class="card-body">

                    <div class="mb-3">
                        <label for="nome" class="form-label fw-semibold">Nome do plano <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="nome" name="nome"
                               value="{{ plano.titulo }}" required>
                    </div>

                    <div class="mb-3">
                        <label for="valor" class="form-label fw-semibold">Valor mensal <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text">R$</span>
                            <input type="text" class="form-control" name="valor" id="valor"
                                   value="{{ plano.valor }}" oninput="validateFloatInput(this)" required>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Status</label>
                        <div class="btn-group w-100" role="group">
                            <input type="radio" class="btn-check" name="status" id="status_ativo"
                                   value="Ativo" autocomplete="off" {{ plano.status == 'Ativo' ? 'checked' : '' }}>
                            <label class="btn btn-outline-success" for="status_ativo">
                                <i class="bi bi-check-circle me-1"></i>Ativo
                            </label>
                            <input type="radio" class="btn-check" name="status" id="status_inativo"
                                   value="Inativo" autocomplete="off" {{ plano.status == 'Inativo' ? 'checked' : '' }}>
                            <label class="btn btn-outline-secondary" for="status_inativo">
                                <i class="bi bi-pause-circle me-1"></i>Inativo
                            </label>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">Período de trial / destaque</label>
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" name="trial"
                                   role="switch" id="trial" {{ plano.trial ? 'checked' : '' }}>
                            <label class="form-check-label" for="trial">
                                Plano em destaque / com período trial
                            </label>
                        </div>
                    </div>

                    {# Info: lojas vinculadas #}
                    <div class="alert alert-light border small py-2 mb-3">
                        <i class="bi bi-info-circle text-primary me-1"></i>
                        Alterações afetarão <strong>novos</strong> estabelecimentos. Assinantes existentes mantêm as condições contratadas.
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-floppy me-1"></i>Salvar alterações
                        </button>
                        <a href="{{ url('app_plano') }}" class="btn btn-outline-secondary">Cancelar</a>
                    </div>

                </div>
            </div>
        </div>

    </div>
</section>
</form>
{% endblock %}

{% block javascripts %}
<script>
function validateFloatInput(input) {
    input.value = input.value.replace(',', '.');
    input.value = input.value.replace(/[^0-9.]/g, '');
    const parts = input.value.split('.');
    if (parts.length > 2) {
        input.value = parts[0] + '.' + parts.slice(1).join('');
    }
}
window.validateFloatInput = validateFloatInput;
</script>
{% endblock %}
