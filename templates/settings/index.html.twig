{% extends 'list/_list_base.html.twig' %}
{% block title %}Configurações globais do Estabelecimento{% endblock %}
{% block list_title %}Configurações globais do Estabelecimento{% endblock %}
{% block breadcrumbsAction %}
{% endblock %}
{% block breadcrumbsGrupo %}Configurações{% endblock %}
{% block breadcrumbsAtivo %}Configurações globais do Estabelecimento{% endblock %}
{% block page_title %}Configurações globais do Estabelecimento{% endblock %}
{% block list_content %}
    <div class="container-fluid py-4">
        
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body p-0 pb-4">
                <!-- NAV TABS -->
                <ul class="nav nav-tabs mb-4 gap-1 ps-0 ms-0" id="configTabs" role="tablist">
                    <li class="nav-item">
                        <button class="nav-link active d-flex align-items-center gap-2" data-bs-toggle="tab" data-bs-target="#geral">
                        <i class="bi bi-building"></i>
                        Geral
                        </button>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link d-flex align-items-center gap-2" href="{{ url('assinatura_painel') }}">
                        <i class="bi bi-credit-card-2-front"></i>
                        Meu Plano
                        </a>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link d-flex align-items-center gap-2" data-bs-toggle="tab" data-bs-target="#pagamentos">
                        <i class="bi bi-credit-card"></i>
                        Pagamentos
                        </button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link d-flex align-items-center gap-2" data-bs-toggle="tab" data-bs-target="#emails">
                        <i class="bi bi-envelope"></i>
                        E-mails
                        </button>
                    </li>
                    <li class="nav-item d-none">
                        <button class="nav-link d-flex align-items-center gap-2" data-bs-toggle="tab" data-bs-target="#ia">
                        <i class="bi bi-cpu"></i>
                        Automação
                        </button>
                    </li>
                    <li class="nav-item d-none">
                        <button class="nav-link d-flex align-items-center gap-2" data-bs-toggle="tab" data-bs-target="#usuarios">
                        <i class="bi bi-people"></i>
                        Permissões
                        </button>
                    </li>
                    <li class="nav-item d-none">
                        <button class="nav-link d-flex align-items-center gap-2" data-bs-toggle="tab" data-bs-target="#marketing">
                        <i class="bi bi-megaphone"></i>
                        Marketing
                        </button>
                    </li>
                    <li class="nav-item d-none">
                        <button class="nav-link d-flex align-items-center gap-2" data-bs-toggle="tab" data-bs-target="#integracoes">
                        <i class="bi bi-diagram-3"></i>
                        Integrações
                        </button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link d-flex align-items-center gap-2" data-bs-toggle="tab" data-bs-target="#lgpd">
                            <i class="bi bi-shield-lock"></i>
                            LGPD
                        </button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link d-flex align-items-center gap-2" data-bs-toggle="tab" data-bs-target="#tracking">
                            <i class="bi bi-graph-up-arrow"></i>
                            Tracking
                        </button>
                    </li>
                </ul>
                <!-- CONTENT -->
                <div class="tab-content p-4">
                    <!-- GERAL -->
                    <div class="tab-pane fade show active" id="geral">
                        <h5 class="fw-bold mb-3">Informações do Estabelecimento</h5>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Razão Social</label>
                                <input class="form-control" name="razaoSocial" value="{{ estabelecimento.razaoSocial }}" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">CNPJ</label>
                                <input class="form-control" name="cnpj" value="{{ estabelecimento.cnpj }}" required>
                            </div>
                            <div class="col-md-8 mb-3">
                                <label class="form-label">Rua</label>
                                <input class="form-control" name="rua" value="{{ estabelecimento.rua }}" required>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Número</label>
                                <input class="form-control" name="numero" value="{{ estabelecimento.numero }}" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Complemento</label>
                                <input class="form-control" name="complemento" value="{{ estabelecimento.complemento }}">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Bairro</label>
                                <input class="form-control" name="bairro" value="{{ estabelecimento.bairro }}" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Cidade</label>
                                <input class="form-control" name="cidade" value="{{ estabelecimento.cidade }}" required>
                            </div>
                            <div class="col-md-3 mb-3">
                                <label class="form-label">País</label>
                                <input class="form-control" name="pais" value="{{ estabelecimento.pais }}">
                            </div>
                            <div class="col-md-3 mb-3">
                                <label class="form-label">CEP</label>
                                <input class="form-control" name="cep" value="{{ estabelecimento.cep }}" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Status do Estabelecimento</label>
                                <select class="form-select" name="status" required>
                                    <option {% if estabelecimento.status == 'Ativo' %} selected {% endif %} value="Ativo">Ativo</option>
                                    <option {% if estabelecimento.status == 'Inativo' %} selected {% endif %} value="Inativo">Inativo</option>
                                    <option {% if estabelecimento.status == 'Suspenso' %} selected {% endif %} value="Suspenso">Suspenso</option>
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Plano</label>
                                <select class="form-select" name="planoId" required>
                                    {% for row in planos %}
                                        <option {% if estabelecimento.planoId == row.id %} selected {% else %} disabled {% endif %} value="{{ row.id }}">{{ row.titulo }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                        </div>
                        <div class="alert alert-info">Tela em desenvolvimento, aguarde novidades!</div>
                        <button class="btn btn-sm btn-success float-end d-none">Saltar alterações</button>
                    </div>
                    <!-- PAGAMENTOS -->
                    <div class="tab-pane fade" id="pagamentos">
                        <h5 class="fw-bold mb-3">Gateways de Pagamento</h5>
                        <form action="{{ url('setting_payment_estabelecimento', {'eid':app.session.get('estabelecimentoId')}) }}" method="post">
                            <div class="alert alert-info">
                                <strong>Atenção:</strong>
                                estamos adicionando novos gateways para adequar a área de pagamentos ao seu perfil financeiro.<br>
                                Para mais informações, entre em contato com o suporte.
                            </div>
                            <div class="row">
                                <label class="card me-2" style="width: 18rem;">
                                    <span class="card-body h-50">
                                        <input type="radio" {% if gateway[0] is defined and gateway[0].valor == 'MERCADO_PAGO' %} checked {% endif %} class="form-check-input mt-3" name="gateway_chave" value="MERCADO_PAGO">
                                        <input type="hidden" name="gateway_tipo" value="gateway">
                                        <input type="hidden" name="gateway_observacao" value="Campo responsável por exibir a seleção do gateway de pagamento">
                                        <img src="{{ asset('images/mp_logo.png') }}" class="card-img-top img-fluid" alt="Logo Mercado Pago">
                                    </span>
                                    <div class="card-body">
                                        <h5 class="card-title">Mercado Pago</h5>
                                    </div>
                                    <div class="card-body">
                                        <a href="https://www.mercadopago.com.br/developers/panel/app" target="_blank" class="btn btn-sm btn-primary w-100">Obter credenciais</a>
                                    </div>
                                </label>
                                <label class="card d-none" style="width: 18rem;">
                                    <span class="card-body h-50">
                                        <input type="radio" class="form-check-input mt-3" name="type_gateway" value="PAG_SEGURO">
                                        <img src="https://1000logos.net/wp-content/uploads/2022/09/PagSeguro-Logo.jpg" class="card-img-top img-fluid mt-5" alt="Logo Mercado Pago">
                                    </span>
                                    <div class="card-body">
                                        <h5 class="card-title">Pag Seguro</h5>
                                    </div>
                                    <div class="card-body">
                                        <a href="https://developer.pagbank.com.br/v1/reference/autenticacao" target="_blank" class="btn btn-sm btn-primary w-100">Obter credenciais</a>
                                    </div>
                                </label>
                            </div>
                            <div class="row">
                                <div class="col-md-3 mb-3">
                                    <label class="form-label" for="gateway_payment_env">Ambiente</label>
                                    <select name="gateway_payment_env" id="gateway_payment_env" class="form-select">
                                        <option {% if gateway[1] is defined and gateway[1].valor == 'sandbox' %} selected {% endif %} value="sandbox">Ambiente de testes</option>
                                        <option {% if gateway[1] is defined and gateway[1].valor == 'production' %} selected {% endif %} value="production">Ambiente de produção</option>
                                    </select>
                                    <input type="hidden" name="gateway_payment_env_tipo" value="gateway">
                                    <input type="hidden" name="gateway_payment_env_observacao" value="Campo responsável por identificar qual o ambiente o gateway está sendo executado.">
                                </div>
                                <div class="col-md-5 mb-3">
                                    <label class="form-label">Token</label>
                                    <input class="form-control" type="text" name="gateway_payment_token" value="{{ gateway[2].valor ?? null }}">
                                    <input type="hidden" name="gateway_payment_token_tipo" value="gateway">
                                    <input type="hidden" name="gateway_payment_token_observacao" value="Campo responsável por identificar o token para o processamento do gateway">
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">E-mail de autenticação</label>
                                    <input class="form-control" type="text" name="gateway_payment_email" value="{{ gateway[3].valor ?? null }}">
                                    <input type="hidden" name="gateway_payment_email_tipo" value="gateway">
                                    <input type="hidden" name="gateway_payment_email_observacao" value="Campo responsável por identificar o e-mail do Estabelecimento para envio de notas e/outras notificações">
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Chave secreta</label>
                                    <input class="form-control" type="text" name="gateway_payment_key_secret" value="{{ gateway[4].valor ?? null }}">
                                    <input type="hidden" name="gateway_payment_key_secret_tipo" value="gateway">
                                    <input type="hidden" name="gateway_payment_key_secret_observacao" value="Este campo é somente utilizado nas requisições do gateway para efetivar o pagamento">
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Chave pública</label>
                                    <input class="form-control" type="text" name="gateway_payment_key_public" value="{{ gateway[5].valor ?? null }}">
                                    <input type="hidden" name="gateway_payment_key_public_tipo" value="gateway">
                                    <input type="hidden" name="gateway_payment_key_public_observacao" value="Este campo também é somente utilizado nas requisições do gateway para efetivar o pagamento">
                                </div>
                            </div>
                            <button type="submit" class="btn btn-sm btn-success float-end">Saltar alterações</button>
                        </form>
                    </div>
                    <!-- EMAILS -->
                    <div class="tab-pane fade" id="emails">
                        <h5 class="fw-bold mb-3">Serviço de E-mail</h5>
                        <form action="{{ url('setting_mailer_estabelecimento', {'eid':app.session.get('estabelecimentoId')}) }}" method="post">
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Servidor SMTP</label>
                                    <input class="form-control" name="mailer_server" value="{{ mailer[0].valor ?? null }}">
                                </div>
                                <div class="col-md-3 mb-3">
                                    <label class="form-label">Porta</label>
                                    <input class="form-control" name="mailer_port" value="{{ mailer[1].valor ?? null }}">
                                </div>
                                <div class="col-md-3 mb-3">
                                    <label class="form-label">Criptografia</label>
                                    <select class="form-select" name="mailer_crypt">
                                        <option {% if mailer[2] is defined and mailer[2].valor == 'tls' %} selected {% endif %} value="tls">TLS</option>
                                        <option {% if mailer[2] is defined and mailer[2].valor == 'ssl' %} selected {% endif %} value="ssl">SSL</option>
                                    </select>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Usuario / E-mail</label>
                                    <input class="form-control" name="mailer_user" value="{{ mailer[3].valor ?? null }}">
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Senha</label>
                                    <div class="input-group mb-3">
                                        <input type="password" class="form-control" id="senha" name="mailer_paswd" value="{{ mailer[4].valor ?? null }}">
                                        <button type="button" class="input-group-text show-hide-paswd" id="basic-addon1" data-target="#senha">
                                            <i class="bi bi-eye"></i>
                                        </button>
                                    </div>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Nome Remetente</label>
                                    <input class="form-control" name="mailer_remetente" value="{{ mailer[5].valor ?? null }}">
                                </div>
                            </div>
                            <button class="btn btn-sm btn-success float-end">Saltar alterações</button>
                        </form>
                    </div>
                    <!-- IA -->
                    {# <div class="tab-pane fade" id="ia">
                        <h5 class="fw-bold mb-3">Configurações de IA</h5>
                        <div class="mb-3">
                            <label class="form-label">API Key da IA</label>
                            <input class="form-control">
                        </div>
                        <button class="btn btn-sm btn-success float-end">Saltar alterações</button>
                    </div>
                    <!-- USUÁRIOS -->
                    <div class="tab-pane fade" id="usuarios">
                        <h5 class="fw-bold mb-3">Permissões & Perfis</h5>
                        <div class="mb-3">
                            <label class="form-label">Modelo de Permissões</label>
                            <select class="form-select">
                                <option>Administrador</option>
                                <option>Operacional</option>
                                <option>Financeiro</option>
                            </select>
                        </div>
                        <button class="btn btn-sm btn-success float-end">Saltar alterações</button>
                    </div>
                    <!-- MARKETING -->
                    <div class="tab-pane fade" id="marketing">
                        <h5 class="fw-bold mb-3">Pixels & Inbound</h5>
                        <div class="mb-3">
                            <label class="form-label">Facebook Pixel</label>
                            <input class="form-control">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Google Tag Manager</label>
                            <input class="form-control">
                        </div>
                        <button class="btn btn-sm btn-success float-end">Saltar alterações</button>
                    </div>
                    <!-- INTEGRAÇÕES -->
                    <div class="tab-pane fade" id="integracoes">
                        <h5 class="fw-bold mb-3">Conexões Externas & APIs</h5>
                        <div class="mb-3">
                            <label class="form-label">Webhook URL</label>
                            <input class="form-control">
                        </div>
                        <button class="btn btn-sm btn-success float-end">Saltar alterações</button>
                    </div> #}

                    {# ══════════════════════════════════════════════════
                       ABA: LGPD — Política de Privacidade e Termos de Uso
                    ══════════════════════════════════════════════════ #}
                    <div class="tab-pane fade" id="lgpd">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h5 class="fw-bold mb-0"><i class="bi bi-shield-lock me-2 text-primary"></i>LGPD — Proteção de Dados</h5>
                            <span class="badge bg-primary-subtle text-primary border border-primary-subtle">Lei 13.709/2018</span>
                        </div>

                        <div class="alert alert-info d-flex gap-2 align-items-start mb-4">
                            <i class="bi bi-info-circle-fill flex-shrink-0 mt-1"></i>
                            <div>
                                Os textos cadastrados aqui são exibidos nas páginas públicas
                                <strong>/politicas-de-privacidade</strong> e <strong>/termos-de-uso</strong>.
                                Mantenha-os atualizados conforme exigido pela LGPD.
                                Em caso de dúvida, consulte seu DPO ou advogado especializado.
                            </div>
                        </div>

                        {# DPO #}
                        <div class="card border-0 bg-light rounded-3 mb-4 p-3">
                            <h6 class="fw-semibold mb-3"><i class="bi bi-person-badge me-1"></i>Encarregado de Dados (DPO)</h6>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label">Nome do DPO</label>
                                    <input type="text" class="form-control lgpd-field" id="dpo_nome"
                                           name="dpo_nome" placeholder="Ex.: Maria Silva"
                                           value="{{ lgpd.dpo_nome ?? '' }}">
                                    <div class="form-text">Obrigatório pela LGPD — Art. 41.</div>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">E-mail do DPO</label>
                                    <input type="email" class="form-control lgpd-field" id="dpo_email"
                                           name="dpo_email" placeholder="dpo@suaempresa.com.br"
                                           value="{{ lgpd.dpo_email ?? '' }}">
                                    <div class="form-text">Disponibilizado ao titular para exercício de direitos.</div>
                                </div>
                            </div>
                        </div>

                        {# Cookie Banner #}
                        <div class="card border-0 bg-light rounded-3 mb-4 p-3">
                            <h6 class="fw-semibold mb-2"><i class="bi bi-cookie me-1"></i>Banner de Consentimento de Cookies</h6>
                            <div class="form-check form-switch">
                                <input class="form-check-input lgpd-field" type="checkbox" role="switch"
                                       id="cookie_banner_ativo" name="cookie_banner_ativo" value="1"
                                       {{ (lgpd.cookie_banner_ativo ?? '0') == '1' ? 'checked' : '' }}>
                                <label class="form-check-label" for="cookie_banner_ativo">
                                    Exibir banner de consentimento nas páginas públicas
                                </label>
                            </div>
                            <div class="form-text mt-1">
                                Quando ativo, o visitante deve aceitar ou recusar cookies antes que os scripts de rastreamento
                                (Google Analytics, Facebook Pixel, etc.) sejam carregados. Recomendado pela ANPD.
                            </div>
                        </div>

                        {# Política de Privacidade #}
                        <div class="mb-4">
                            <label class="form-label fw-semibold">
                                <i class="bi bi-file-earmark-lock2 me-1"></i>Política de Privacidade
                                <span class="badge bg-danger ms-1">Obrigatório</span>
                            </label>
                            <div id="editor-politica" class="quill-editor-area" style="min-height:320px;">{{ lgpd.politica_privacidade ?? ''|raw }}</div>
                            <textarea id="politica_privacidade" name="politica_privacidade" class="d-none lgpd-field">{{ lgpd.politica_privacidade ?? '' }}</textarea>
                            <div class="form-text">
                                Informe: quais dados são coletados, finalidade, base legal, tempo de retenção, direitos do titular e contato do DPO.
                            </div>
                        </div>

                        {# Termos de Uso #}
                        <div class="mb-4">
                            <label class="form-label fw-semibold">
                                <i class="bi bi-file-earmark-text me-1"></i>Termos de Uso
                            </label>
                            <div id="editor-termos" class="quill-editor-area" style="min-height:280px;">{{ lgpd.termos_uso ?? ''|raw }}</div>
                            <textarea id="termos_uso" name="termos_uso" class="d-none lgpd-field">{{ lgpd.termos_uso ?? '' }}</textarea>
                        </div>

                        <div class="d-flex justify-content-end">
                            <button type="button" class="btn btn-primary px-5" id="btnSalvarLgpd">
                                <i class="bi bi-floppy me-1"></i>Salvar configurações LGPD
                            </button>
                        </div>
                    </div>

                    {# ══════════════════════════════════════════════════
                       ABA: TRACKING — Pixels e Tags
                    ══════════════════════════════════════════════════ #}
                    <div class="tab-pane fade" id="tracking">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h5 class="fw-bold mb-0"><i class="bi bi-graph-up-arrow me-2 text-success"></i>Rastreamento & Analytics</h5>
                        </div>

                        <div class="alert alert-warning d-flex gap-2 align-items-start mb-4">
                            <i class="bi bi-exclamation-triangle-fill flex-shrink-0 mt-1"></i>
                            <div>
                                Scripts de rastreamento só são injetados nas páginas públicas quando o visitante
                                <strong>aceita cookies</strong> (banner LGPD ativo) ou quando o banner está desabilitado.
                                Respeite a escolha do usuário conforme exigência da LGPD e da ANPD.
                            </div>
                        </div>

                        <div class="row g-4">
                            {# Google Analytics 4 #}
                            <div class="col-md-6">
                                <div class="card border-0 bg-light rounded-3 h-100 p-3">
                                    <div class="d-flex align-items-center gap-2 mb-3">
                                        <img src="https://www.gstatic.com/analytics-suite/header/suite/v2/ic_analytics.svg"
                                             width="28" alt="GA4" onerror="this.style.display='none'">
                                        <h6 class="mb-0 fw-semibold">Google Analytics 4</h6>
                                    </div>
                                    <label class="form-label">ID de Medição <span class="text-muted fw-normal">(ex: G-XXXXXXXXXX)</span></label>
                                    <input type="text" class="form-control tracking-field" name="google_analytics_id"
                                           placeholder="G-XXXXXXXXXX"
                                           value="{{ tracking.google_analytics_id ?? '' }}">
                                    <div class="form-text mt-2">
                                        <a href="https://analytics.google.com" target="_blank" class="text-decoration-none">
                                            <i class="bi bi-box-arrow-up-right me-1"></i>Obter ID no Google Analytics
                                        </a>
                                    </div>
                                </div>
                            </div>

                            {# Google Tag Manager #}
                            <div class="col-md-6">
                                <div class="card border-0 bg-light rounded-3 h-100 p-3">
                                    <div class="d-flex align-items-center gap-2 mb-3">
                                        <i class="bi bi-tags-fill text-primary fs-5"></i>
                                        <h6 class="mb-0 fw-semibold">Google Tag Manager</h6>
                                    </div>
                                    <label class="form-label">ID do Container <span class="text-muted fw-normal">(ex: GTM-XXXXXXX)</span></label>
                                    <input type="text" class="form-control tracking-field" name="google_tag_manager_id"
                                           placeholder="GTM-XXXXXXX"
                                           value="{{ tracking.google_tag_manager_id ?? '' }}">
                                    <div class="form-text mt-2">
                                        <a href="https://tagmanager.google.com" target="_blank" class="text-decoration-none">
                                            <i class="bi bi-box-arrow-up-right me-1"></i>Acessar Google Tag Manager
                                        </a>
                                    </div>
                                </div>
                            </div>

                            {# Facebook Pixel #}
                            <div class="col-md-6">
                                <div class="card border-0 bg-light rounded-3 h-100 p-3">
                                    <div class="d-flex align-items-center gap-2 mb-3">
                                        <i class="bi bi-meta text-primary fs-5"></i>
                                        <h6 class="mb-0 fw-semibold">Meta (Facebook) Pixel</h6>
                                    </div>
                                    <label class="form-label">ID do Pixel <span class="text-muted fw-normal">(ex: 1234567890123)</span></label>
                                    <input type="text" class="form-control tracking-field" name="facebook_pixel_id"
                                           placeholder="1234567890123"
                                           value="{{ tracking.facebook_pixel_id ?? '' }}">
                                    <div class="form-text mt-2">
                                        <a href="https://business.facebook.com/events_manager" target="_blank" class="text-decoration-none">
                                            <i class="bi bi-box-arrow-up-right me-1"></i>Gerenciar no Meta Business
                                        </a>
                                    </div>
                                </div>
                            </div>

                            {# Google Ads #}
                            <div class="col-md-6">
                                <div class="card border-0 bg-light rounded-3 h-100 p-3">
                                    <div class="d-flex align-items-center gap-2 mb-3">
                                        <i class="bi bi-google text-danger fs-5"></i>
                                        <h6 class="mb-0 fw-semibold">Google Ads</h6>
                                    </div>
                                    <label class="form-label">ID de Conversão <span class="text-muted fw-normal">(ex: AW-XXXXXXXXX)</span></label>
                                    <input type="text" class="form-control tracking-field" name="google_ads_id"
                                           placeholder="AW-XXXXXXXXX"
                                           value="{{ tracking.google_ads_id ?? '' }}">
                                    <div class="form-text mt-2">
                                        <a href="https://ads.google.com" target="_blank" class="text-decoration-none">
                                            <i class="bi bi-box-arrow-up-right me-1"></i>Acessar Google Ads
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end mt-4">
                            <button type="button" class="btn btn-success px-5" id="btnSalvarTracking">
                                <i class="bi bi-floppy me-1"></i>Salvar configurações de rastreamento
                            </button>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
{% endblock %}
{% block javascripts %}
    <link href="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.snow.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.js"></script>
    <style>
        .quill-editor-area { background: #fff; border: 1px solid #dee2e6; border-radius: .375rem; }
        .ql-toolbar { border-radius: .375rem .375rem 0 0; border-color: #dee2e6 !important; }
        .ql-container { border-radius: 0 0 .375rem .375rem; border-color: #dee2e6 !important; font-size: .95rem; }
    </style>
    <script>
    $(function () {

        // ── Show/hide password ────────────────────────────────────────
        $('.show-hide-paswd').on('click', function () {
            const $btn = $(this);
            const $icon = $btn.find('i');
            const $input = $($btn.data('target'));
            const visivel = $btn.toggleClass('show').hasClass('show');
            $input.attr('type', visivel ? 'text' : 'password');
            $icon.toggleClass('bi-eye', visivel).toggleClass('bi-eye-slash', !visivel);
        });

        // ── Quill — Política de Privacidade ──────────────────────────
        const quillPolitica = new Quill('#editor-politica', {
            theme: 'snow',
            modules: {
                toolbar: [
                    [{ header: [1, 2, 3, false] }],
                    ['bold', 'italic', 'underline'],
                    [{ list: 'ordered' }, { list: 'bullet' }],
                    ['link'],
                    ['clean']
                ]
            }
        });

        // ── Quill — Termos de Uso ─────────────────────────────────────
        const quillTermos = new Quill('#editor-termos', {
            theme: 'snow',
            modules: {
                toolbar: [
                    [{ header: [1, 2, 3, false] }],
                    ['bold', 'italic', 'underline'],
                    [{ list: 'ordered' }, { list: 'bullet' }],
                    ['link'],
                    ['clean']
                ]
            }
        });

        // ── Sinc Quill → textarea hidden antes de salvar ─────────────
        function sincQuill() {
            $('#politica_privacidade').val(quillPolitica.root.innerHTML);
            $('#termos_uso').val(quillTermos.root.innerHTML);
        }

        // ── Salvar LGPD via AJAX ──────────────────────────────────────
        $('#btnSalvarLgpd').on('click', function () {
            sincQuill();
            const $btn = $(this).prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-1"></span>Salvando...');
            const dados = {};
            $('.lgpd-field').each(function () {
                const el = $(this);
                if (el.attr('type') === 'checkbox') {
                    dados[el.attr('name')] = el.is(':checked') ? '1' : '0';
                } else {
                    dados[el.attr('name')] = el.val();
                }
            });

            $.ajax({
                url   : '{{ path('settings_lgpd_salvar') }}',
                method: 'POST',
                data  : dados,
                success: function (r) {
                    toastSucesso(r.message ?? 'Configurações LGPD salvas!');
                },
                error: function () {
                    toastErro('Erro ao salvar configurações LGPD.');
                },
                complete: function () {
                    $btn.prop('disabled', false).html('<i class="bi bi-floppy me-1"></i>Salvar configurações LGPD');
                }
            });
        });

        // ── Salvar Tracking via AJAX ──────────────────────────────────
        $('#btnSalvarTracking').on('click', function () {
            const $btn = $(this).prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-1"></span>Salvando...');
            const dados = {};
            $('.tracking-field').each(function () {
                dados[$(this).attr('name')] = $(this).val();
            });

            $.ajax({
                url   : '{{ path('settings_tracking_salvar') }}',
                method: 'POST',
                data  : dados,
                success: function (r) {
                    toastSucesso(r.message ?? 'Configurações de rastreamento salvas!');
                },
                error: function () {
                    toastErro('Erro ao salvar rastreamento.');
                },
                complete: function () {
                    $btn.prop('disabled', false).html('<i class="bi bi-floppy me-1"></i>Salvar configurações de rastreamento');
                }
            });
        });

        // ── Toast helpers ─────────────────────────────────────────────
        function toastSucesso(msg) { mostrarToast(msg, 'success'); }
        function toastErro(msg)    { mostrarToast(msg, 'danger'); }
        function mostrarToast(msg, tipo) {
            const id = 'toast_' + Date.now();
            const html = `<div id="${id}" class="toast align-items-center text-bg-${tipo} border-0 show position-fixed bottom-0 end-0 m-3" style="z-index:9999" role="alert">
                <div class="d-flex">
                    <div class="toast-body fw-semibold">${msg}</div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                </div>
            </div>`;
            $('body').append(html);
            setTimeout(() => { $(`#${id}`).remove(); }, 4000);
        }

    });
    </script>
{% endblock %}