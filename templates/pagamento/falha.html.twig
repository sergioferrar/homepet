{% extends 'home/baseLanding.html.twig' %}

{% block title %}Falha no Pagamento{% endblock %}
{% block meta_description %}Não foi possível concluir a transação de pagamento. Tente novamente.{% endblock %}
{% block meta_robots %}noindex, nofollow{% endblock %}

{% block body %}
    {% include 'pagamento/_status_pagamento.html.twig' with {
        icone: 'bi-exclamation-triangle-fill',
        cor: '#DC2626',
        cor_fundo: '#FEE2E2',
        titulo: 'Não foi possível concluir o pagamento',
        linhas: [
            'Infelizmente, ocorreu uma falha ao processar sua transação.',
            'Verifique os dados e tente novamente ou utilize outro método de pagamento. Se o problema persistir, fale com o nosso suporte.'
        ],
        mensagem: erro is defined ? erro : null,
        acoes: [
            { href: url('landing_planos'), label: 'Tentar Novamente', primario: true, icone: 'bi-arrow-clockwise' },
            { href: url('landing_home') ~ '#contato', label: 'Falar com o Suporte', primario: false, icone: 'bi-chat-dots' }
        ]
    } %}
{% endblock %}
