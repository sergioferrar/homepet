{% extends 'home/baseLanding.html.twig' %}

{% block title %}Recursos{% endblock %}
{% block meta_description %}Conheça todos os recursos do System Home Pet: gestão de clientes e pets, prontuário veterinário, vacinas, financeiro, agenda, banho e tosa, estoque e relatórios gerenciais.{% endblock %}
{% block meta_keywords %}recursos sistema pet shop, prontuário veterinário, controle de vacinas, agenda veterinária, banho e tosa, estoque pet shop, financeiro clínica veterinária{% endblock %}

{% block body %}
{# ── Cabeçalho da página ─────────────────────────────────────────── #}
<section class="page-hero-section">
    <div class="container">
        <div class="row justify-content-center text-center">
            <div class="col-lg-7" data-fade>
                <span class="section-tag">Recursos</span>
                <h1 class="hero-headline" style="font-size:clamp(2rem,5vw,3rem);">
                    Tudo que seu negócio precisa,<br/>
                    <span class="line-teal">em um só lugar</span>
                </h1>
                <p class="hero-sub" style="max-width:560px;margin:0 auto 2rem;">
                    Do atendimento ao controle financeiro, o System Home Pet cobre cada etapa
                    da operação do seu estabelecimento.
                </p>
                <div class="d-flex flex-wrap gap-3 justify-content-center mb-2">
                    <a href="{{ url('landing_planos') }}" class="btn btn-primary-custom">
                        Ver Planos <i class="bi bi-arrow-right"></i>
                    </a>
                    <a href="{{ url('landing_home') }}" class="btn btn-outline-custom">
                        <i class="bi bi-arrow-left me-1"></i> Voltar ao início
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

{# ── Grid completo de recursos ───────────────────────────────────── #}
<section class="features-section" id="recursos" style="padding-top:60px;">
    <div class="container">
        <div class="row g-4">
            <div class="col-12 col-sm-6 col-lg-4" data-fade>
                <div class="feature-card">
                    <div class="feature-icon-wrap"><i class="bi bi-people-fill"></i></div>
                    <div class="feature-title">Gestão de Clientes e Pets</div>
                    <div class="feature-desc">Cadastro completo de tutores e seus animais com histórico de atendimentos
                        e informações detalhadas.
                    </div>
                </div>
            </div>
            <div class="col-12 col-sm-6 col-lg-4" data-fade>
                <div class="feature-card">
                    <div class="feature-icon-wrap"><i class="bi bi-clipboard2-pulse-fill"></i></div>
                    <div class="feature-title">Prontuário Veterinário</div>
                    <div class="feature-desc">Registros clínicos completos, anotações, diagnósticos e prescrições
                        organizados por pet e data.
                    </div>
                </div>
            </div>
            <div class="col-12 col-sm-6 col-lg-4" data-fade>
                <div class="feature-card">
                    <div class="feature-icon-wrap"><i class="bi bi-shield-plus"></i></div>
                    <div class="feature-title">Controle de Vacinas</div>
                    <div class="feature-desc">Calendário vacinal automatizado com lembretes para tutores e visão
                        completa do histórico imunológico.
                    </div>
                </div>
            </div>
            <div class="col-12 col-sm-6 col-lg-4" data-fade>
                <div class="feature-card">
                    <div class="feature-icon-wrap"><i class="bi bi-currency-dollar"></i></div>
                    <div class="feature-title">Controle Financeiro</div>
                    <div class="feature-desc">Fluxo de caixa, contas a pagar/receber, DRE simplificado e conciliação
                        financeira em tempo real.
                    </div>
                </div>
            </div>
            <div class="col-12 col-sm-6 col-lg-4" data-fade>
                <div class="feature-card">
                    <div class="feature-icon-wrap"><i class="bi bi-calendar3-week-fill"></i></div>
                    <div class="feature-title">Agenda de Consultas</div>
                    <div class="feature-desc">Agendamento online integrado, gestão de horários por veterinário e
                        confirmação automática por e-mail.
                    </div>
                </div>
            </div>
            <div class="col-12 col-sm-6 col-lg-4" data-fade>
                <div class="feature-card">
                    <div class="feature-icon-wrap"><i class="bi bi-scissors"></i></div>
                    <div class="feature-title">Banho &amp; Tosa</div>
                    <div class="feature-desc">Controle completo de serviços de estética pet, fila de espera e
                        acompanhamento em tempo real pelo tutor.
                    </div>
                </div>
            </div>
            <div class="col-12 col-sm-6 col-lg-4" data-fade>
                <div class="feature-card">
                    <div class="feature-icon-wrap"><i class="bi bi-box-seam-fill"></i></div>
                    <div class="feature-title">Controle de Estoque</div>
                    <div class="feature-desc">Entradas, saídas, alertas de estoque mínimo e relatório de giro de
                        produtos com curva ABC.
                    </div>
                </div>
            </div>
            <div class="col-12 col-sm-6 col-lg-4" data-fade>
                <div class="feature-card">
                    <div class="feature-icon-wrap"><i class="bi bi-graph-up-arrow"></i></div>
                    <div class="feature-title">Relatórios Gerenciais</div>
                    <div class="feature-desc">Dashboards personalizáveis, exportação em PDF/Excel e insights para tomada
                        de decisão estratégica.
                    </div>
                </div>
            </div>
            <div class="col-12 col-sm-6 col-lg-4" data-fade>
                <div class="feature-card">
                    <div class="feature-icon-wrap"><i class="bi bi-person-badge-fill"></i></div>
                    <div class="feature-title">Usuários por Nível de Acesso</div>
                    <div class="feature-desc">Admin, veterinário, atendente, caixa e outros perfis com permissões
                        granulares para máxima segurança.
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

{# ── Como funciona ───────────────────────────────────────────────── #}
<section class="how-section" id="como-funciona">
    <div class="container">
        <div class="row justify-content-center mb-5">
            <div class="col-lg-6 text-center" data-fade>
                <span class="section-tag">Como Funciona</span>
                <h2 class="section-title">Pronto para usar em<br/>menos de 5 minutos</h2>
                <p style="color:var(--text-secondary);">Nosso processo de onboarding foi projetado para ser simples,
                rápido e seguro.</p>
            </div>
        </div>
        <div class="row justify-content-center">
            <div class="col-12 col-lg-8">
                <div class="timeline-wrap ps-2">
                    <div class="timeline-line"></div>
                    <div class="timeline-step" data-fade>
                        <div class="step-number">1</div>
                        <div class="step-content">
                            <h4>Cadastro do Estabelecimento</h4>
                            <p>O responsável acessa a página de cadastro e informa os dados do pet shop ou clínica. O
                            processo leva menos de 2 minutos.</p>
                        </div>
                    </div>
                    <div class="timeline-step" data-fade>
                        <div class="step-number">2</div>
                        <div class="step-content">
                            <h4>Confirmação por E-mail</h4>
                            <p>Um e-mail automático é enviado ao endereço cadastrado com um link de ativação exclusivo e
                            com validade de 24 horas.</p>
                        </div>
                    </div>
                    <div class="timeline-step" data-fade>
                        <div class="step-number">3</div>
                        <div class="step-content">
                            <h4>Criação do Usuário Administrador</h4>
                            <p>Ao clicar no link, o responsável cria o usuário ADMIN do estabelecimento — com acesso
                            total ao sistema e configurações.</p>
                        </div>
                    </div>
                    <div class="timeline-step" data-fade>
                        <div class="step-number">4</div>
                        <div class="step-content">
                            <h4>Cadastro da Equipe</h4>
                            <p>O administrador cadastra todos os colaboradores: <strong>operador de caixa, banho &amp;
                            tosa, veterinários, atendentes</strong> e outros com permissões específicas.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="text-center mt-4" data-fade>
            <a href="{{ url('landing_planos') }}" class="btn btn-primary-custom">
                Começar Agora <i class="bi bi-arrow-right"></i>
            </a>
        </div>
    </div>
</section>
{% endblock %}
