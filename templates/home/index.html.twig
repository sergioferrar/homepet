{% extends 'base.html.twig' %}

{% block body %}
    <div class="row justify-content-center mb-4">
        <div class="col-md-10 col-lg-8">
            <div class="bg-transparent text-center px-4 py-3 border-0 text-center">
                <center>
                    <svg width="400" height="100" viewBox="0 0 900 220" xmlns="http://www.w3.org/2000/svg">
                        <defs>
                        <linearGradient id="markGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                            <stop offset="0%" stop-color="#14B8A6"/>
                            <stop offset="100%" stop-color="#14B8A6"/>
                        </linearGradient>
                        </defs>
                        <g transform="translate(20,0)">
                            <rect x="0" y="0" width="220" height="220" rx="52" fill="url(#markGrad)"/>
                            <g fill="#FFFFFF">
                                <ellipse cx="110" cy="150" rx="52" ry="42"/>
                                <ellipse cx="55" cy="98" rx="21" ry="26" transform="rotate(-18 55 98)"/>
                                <ellipse cx="95" cy="66" rx="22" ry="28" transform="rotate(-6 95 66)"/>
                                <ellipse cx="140" cy="64" rx="22" ry="28" transform="rotate(6 140 64)"/>
                                <ellipse cx="178" cy="94" rx="21" ry="26" transform="rotate(18 178 94)"/>
                            </g>
                            <g fill="url(#markGrad)">
                                <rect x="97" y="126" width="26" height="52" rx="6"/>
                                <rect x="84" y="139" width="52" height="26" rx="6"/>
                            </g>
                        </g>
                        <text x="272" y="95" font-family="Poppins, sans-serif" font-size="100" font-weight="500" letter-spacing="3" fill="#5B6472">System</text>
                        <text x="272" y="165" font-family="Poppins, sans-serif" font-size="90" font-weight="700" fill="#14B8A6">Home<tspan fill="#FDBA74">PET</tspan></text>
                        <text x="272" y="205" font-family="Poppins, sans-serif" font-size="22" font-weight="400" fill="#5B6472">Gestão para Pet shop e clínicas veterinárias</text>
                    </svg>
                </center>
            </div>
        </div>
    </div>

    <div class="row g-4 justify-content-center">
        <div class="col-md-6 col-lg-3">
            <a href="{{ path('agendamento_novo') }}" class="text-decoration-none">
                <div class="card text-white bg-primary card-menu shadow text-center h-100">
                    <div class="card-body py-3 d-flex flex-column justify-content-center align-items-center">
                        <i class="fa-solid fa-calendar-plus fa-xl mb-2"></i>
                        <h6 class="mb-0 mt-3">Novo Agendamento</h6>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-6 col-lg-3">
            <a href="{{ path('cliente_novo') }}" class="text-decoration-none">
                <div class="card text-white bg-success card-menu shadow text-center h-100">
                    <div class="card-body py-3 d-flex flex-column justify-content-center align-items-center">
                        <i class="fa-solid fa-user-plus fa-xl mb-2"></i>
                        <h6 class="mb-0 mt-3">Cadastro de Cliente</h6>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-6 col-lg-3">
            <a href="{{ path('pet_novo') }}" class="text-decoration-none">
                <div class="card text-white bg-warning card-menu shadow text-center h-100">
                    <div class="card-body py-3 d-flex flex-column justify-content-center align-items-center">
                        <i class="fa-solid fa-dog fa-xl mb-2" style="color: black;"></i>
                        <h6 class="mb-0 mt-3 text-dark">Cadastro de Pet</h6>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-6 col-lg-3">
            <a href="{{ path('servico_novo') }}" class="text-decoration-none">
                <div class="card text-white bg-info card-menu shadow text-center h-100">
                    <div class="card-body py-3 d-flex flex-column justify-content-center align-items-center">
                        <i class="fa-solid fa-scissors fa-xl mb-2"></i>
                        <h6 class="mb-0 mt-3">Cadastro de Serviço</h6>
                    </div>
                </div>
            </a>
        </div>
    </div>
    <br>




    <section class="section dashboard">
        <div class="row">

            <!-- Left side columns -->
            <div class="col-lg-12">
                <div class="row">

                    <!-- Sales Card -->
                    <div class="col-xxl-3 col-md-6">
                        <div class="card info-card sales-card">


                            <div class="card-body">
                                <h5 class="card-title">Agendamento <span>| Mês</span></h5>

                                <div class="d-flex align-items-center">
                                    <div class="card-icon rounded-circle d-flex align-items-center justify-content-center">
                                        <i class="bi bi-calendar3"></i>
                                    </div>
                                    <div class="ps-3">
                                        <h6>{{ agendamento }}</h6>
                                        <span class="text-success small pt-1 fw-bold d-none">0%</span> <span
                                                class="text-muted small pt-2 ps-1">increase</span>

                                    </div>
                                </div>
                            </div>

                        </div>
                    </div><!-- End Sales Card -->

                    <!-- Revenue Card -->
                    <div class="col-xxl-3 col-md-6">
                        <div class="card info-card revenue-card">


                            <div class="card-body">
                                <h5 class="card-title">Agendamentos <span>| Hoje</span></h5>

                                <div class="d-flex align-items-center">
                                    <div class="card-icon rounded-circle d-flex align-items-center justify-content-center">
                                        <i class="bi bi-calendar3"></i>
                                    </div>
                                    <div class="ps-3">
                                        <h6>{{ agendamentoHoje }}</h6>
                                        <span class="text-success small pt-1 fw-bold d-none">8%</span> <span
                                                class="text-muted small pt-2 ps-1">increase</span>

                                    </div>
                                </div>
                            </div>

                        </div>
                    </div><!-- End Revenue Card -->

                    <!-- Customers Card -->
                    <div class="col-xxl-3 col-xl-12">

                        <div class="card info-card customers-card">


                            <div class="card-body">
                                <h5 class="card-title">Receita</h5>

                                <div class="d-flex align-items-center">
                                    <div class="card-icon rounded-circle d-flex align-items-center justify-content-center">
                                        <i class="bi bi-currency-dollar"></i>
                                    </div>
                                    <div class="ps-3">
                                        <h6>R$ {{ lucrototal }}</h6>
                                        <span class="text-danger small pt-1 fw-bold d-none">6%</span>
                                        <span class="text-muted small pt-2 ps-1 d-none">decrease</span>

                                    </div>
                                </div>

                            </div>
                        </div>

                    </div><!-- End Customers Card -->
                    <div class="col-xxl-3 col-xl-12">

                        <div class="card info-card customers-card">


                            <div class="card-body">
                                <h5 class="card-title">Pets Cadastrados</h5>

                                <div class="d-flex align-items-center">
                                    <div class="card-icon rounded-circle d-flex align-items-center justify-content-center">
                                        <i class="bi bi-journal-bookmark"></i>
                                    </div>
                                    <div class="ps-3">
                                        <h6>{{ animais }}</h6>
                                        <span class="text-danger small pt-1 fw-bold d-none">12%</span>
                                        <span class="text-muted small pt-2 ps-1 d-none">decrease</span>

                                    </div>
                                </div>

                            </div>
                        </div>

                    </div><!-- End Customers Card -->

                    <!-- Reports -->

                    <!-- Recent Sales -->

                    <!-- Top Selling -->

                </div>
            </div><!-- End Left side columns -->

            <!-- Right side columns -->
            <!-- Reports -->
            <div class="col-12">
                <div class="card">


                    <div class="card-body">
                        <h5 class="card-title">Receita <span>/Diária</span></h5>

                        <!-- Line Chart -->
                        <div id="reportsChart"></div>

                        <script>
                            document.addEventListener("DOMContentLoaded", () => {
                                new ApexCharts(document.querySelector("#reportsChart"), {
                                    series: [{
                                        name: 'Sales',
                                        data: {{ valores|raw }},
                                    },],
                                    chart: {
                                        height: 350,
                                        type: 'area',
                                        toolbar: {
                                            show: false
                                        },
                                    },
                                    markers: {
                                        size: 4
                                    },
                                    colors: ['#4154f1'],
                                    fill: {
                                        type: "gradient",
                                        gradient: {
                                            shadeIntensity: 1,
                                            opacityFrom: 0.3,
                                            opacityTo: 0.4,
                                            stops: [0, 90, 100]
                                        }
                                    },
                                    dataLabels: {
                                        enabled: false
                                    },
                                    stroke: {
                                        curve: 'smooth',
                                        width: 2
                                    },
                                    xaxis: {
                                        type: 'datetime',
                                        categories: {{ datas|raw }}
                                    },
                                    tooltip: {
                                        x: {
                                            format: 'dd/MM/yy HH:mm'
                                        },
                                    }
                                }).render();
                            });
                        </script>
                        <!-- End Line Chart -->

                    </div>

                </div>
            </div><!-- End Reports -->
        </div>
    </section>


    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

{% endblock %}
