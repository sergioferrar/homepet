{% extends 'home/baseLanding.html.twig' %}

{% block title %}System Home Pet{% endblock %}
{% block meta_description %}Sistema de gestão completo para pet shops e clínicas veterinárias: agenda, prontuário, vacinas, financeiro, estoque, banho e tosa. Comece em menos de 5 minutos.{% endblock %}
{% block meta_keywords %}sistema para pet shop, sistema para clínica veterinária, software petshop, gestão pet, prontuário veterinário online{% endblock %}

{% block body %}
    <section class="hero-section" id="inicio">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6">
                    <div class="hero-badge">
                        <i class="bi bi-lightning-charge-fill"></i>
                        Gestão completa em uma plataforma
                    </div>
                    <h1 class="hero-headline text-break">
                        O sistema completo para<br/>
                        <span class="line-teal">Pet Shops</span> &amp;<br/>
                        Clínicas Veterinárias
                    </h1>
                    <p class="hero-sub">
                        Centralize agendamentos, prontuários, financeiro, estoque e muito mais.
                        Uma solução moderna pensada para quem trabalha com o cuidado dos pets.
                    </p>
                    <div class="d-flex flex-wrap gap-3">
                        <a href="{{ url('landing_planos') }}" class="btn btn-primary-custom">
                            Começar Agora <i class="bi bi-arrow-right"></i>
                        </a>
                        <a href="{{ url('landing_recursos') }}" class="btn btn-outline-custom">Conhecer os Recursos</a>
                    </div>
                    <div class="hero-stats row g-3 mt-4 row-cols-1 row-cols-sm-3">
                        <div class="col">
                            <div class="hero-stat-num">+2.400</div>
                            <div class="hero-stat-label">Estabelecimentos ativos</div>
                        </div>
                        <div class="col">
                            <div class="hero-stat-num">+18k</div>
                            <div class="hero-stat-label">Pets cadastrados</div>
                        </div>
                        <div class="col">
                            <div class="hero-stat-num">99.9%</div>
                            <div class="hero-stat-label">Uptime garantido</div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6 mt-5 mt-lg-0">
                    <div class="hero-mockup-wrap" style="overflow-x: auto; max-width: 100%;">
                        <div class="hero-mockup" style="min-width: 280px;">
                            <div class="mockup-bar">
                                <div class="mockup-dot mockup-dot-red"></div>
                                <div class="mockup-dot mockup-dot-yellow"></div>
                                <div class="mockup-dot mockup-dot-green"></div>
                                <div class="flex-grow-1 mx-3"
                                style="background:var(--border);height:18px;border-radius:6px;"></div>
                            </div>
                            <div class="mockup-body">
                                <div class="row g-3">
                                    <div class="col-12 col-md-3">
                                        <div class="dash-sidebar h-100 d-flex flex-row flex-md-column flex-wrap gap-2 justify-content-between justify-content-md-start">
                                            <div class="dash-nav-item active"><i class="bi bi-grid"></i> Painel</div>
                                            <div class="dash-nav-item"><i class="bi bi-calendar3"></i> Agenda</div>
                                            <div class="dash-nav-item"><i class="bi bi-people"></i> Clientes</div>
                                            <div class="dash-nav-item"><i class="bi bi-heart"></i> Pets</div>
                                            <div class="dash-nav-item"><i class="bi bi-box"></i> Estoque</div>
                                            <div class="dash-nav-item"><i class="bi bi-graph-up"></i> Relatórios</div>
                                        </div>
                                    </div>
                                    <div class="col-12 col-md-9">
                                        <div class="row g-2 mb-3 row-cols-1 row-cols-sm-3">
                                            <div class="col">
                                                <div class="dash-metric-card">
                                                    <div class="dash-metric-num">87</div>
                                                    <div class="dash-metric-label">Consultas hoje</div>
                                                    <div class="dash-bar">
                                                        <div class="dash-bar-fill" style="width:87%"></div>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col">
                                                <div class="dash-metric-card">
                                                    <div class="dash-metric-num">R$4,2k</div>
                                                    <div class="dash-metric-label">Faturamento</div>
                                                    <div class="dash-bar">
                                                        <div class="dash-bar-fill"
                                                        style="width:62%;background:var(--accent)"></div>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col">
                                                <div class="dash-metric-card">
                                                    <div class="dash-metric-num">34</div>
                                                    <div class="dash-metric-label">Novos clientes</div>
                                                    <div class="dash-bar">
                                                        <div class="dash-bar-fill"
                                                        style="width:45%;background:#7c6fcd"></div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <div style="background:var(--bg-subtle);border:1px solid var(--border);border-radius:10px;padding:1rem;">
                                            <div style="font-size:.72rem;color:var(--text-muted);font-weight:700;letter-spacing:.08em;text-transform:uppercase;margin-bottom:.8rem;">
                                                ATENDIMENTOS / SEMANA
                                            </div>
                                            <div style="display:flex;align-items:flex-end;gap:5px;height:60px;">
                                                <div style="flex:1;background:var(--teal-light);border-radius:4px 4px 0 0;height:40%"></div>
                                                <div style="flex:1;background:var(--teal-light);border-radius:4px 4px 0 0;height:65%"></div>
                                                <div style="flex:1;background:var(--teal);border-radius:4px 4px 0 0;height:55%"></div>
                                                <div style="flex:1;background:var(--teal-light);border-radius:4px 4px 0 0;height:80%"></div>
                                                <div style="flex:1;background:var(--teal-light);border-radius:4px 4px 0 0;height:50%"></div>
                                                <div style="flex:1;background:var(--teal);border-radius:4px 4px 0 0;height:90%"></div>
                                                <div style="flex:1;background:var(--teal-light);border-radius:4px 4px 0 0;height:70%"></div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    

    

    

    

    
    {# ── RESUMO DE RECURSOS (versão enxuta — página completa em /recursos) ── #}
    <section class="features-section" id="recursos">
        <div class="container">
            <div class="text-center mb-5" data-fade>
                <span class="section-tag">Recursos</span>
                <h2 class="section-title">Tudo que seu negócio precisa,<br/>em um só lugar</h2>
                <p style="color:var(--text-secondary);max-width:560px;margin:0 auto;">
                    Do atendimento ao controle financeiro. Veja alguns destaques — a lista completa está na página de recursos.
                </p>
            </div>
            <div class="row g-4">
                <div class="col-12 col-sm-6 col-lg-4" data-fade>
                    <div class="feature-card">
                        <div class="feature-icon-wrap"><i class="bi bi-people-fill"></i></div>
                        <div class="feature-title">Gestão de Clientes e Pets</div>
                        <div class="feature-desc">Cadastro completo de tutores e seus animais com histórico de atendimentos.</div>
                    </div>
                </div>
                <div class="col-12 col-sm-6 col-lg-4" data-fade>
                    <div class="feature-card">
                        <div class="feature-icon-wrap"><i class="bi bi-clipboard2-pulse-fill"></i></div>
                        <div class="feature-title">Prontuário Veterinário</div>
                        <div class="feature-desc">Registros clínicos, diagnósticos e prescrições organizados por pet e data.</div>
                    </div>
                </div>
                <div class="col-12 col-sm-6 col-lg-4" data-fade>
                    <div class="feature-card">
                        <div class="feature-icon-wrap"><i class="bi bi-calendar3-week-fill"></i></div>
                        <div class="feature-title">Agenda de Consultas</div>
                        <div class="feature-desc">Agendamento integrado, horários por veterinário e confirmação automática.</div>
                    </div>
                </div>
                <div class="col-12 col-sm-6 col-lg-4" data-fade>
                    <div class="feature-card">
                        <div class="feature-icon-wrap"><i class="bi bi-currency-dollar"></i></div>
                        <div class="feature-title">Controle Financeiro</div>
                        <div class="feature-desc">Fluxo de caixa, contas a pagar/receber e conciliação em tempo real.</div>
                    </div>
                </div>
                <div class="col-12 col-sm-6 col-lg-4" data-fade>
                    <div class="feature-card">
                        <div class="feature-icon-wrap"><i class="bi bi-scissors"></i></div>
                        <div class="feature-title">Banho &amp; Tosa</div>
                        <div class="feature-desc">Fila de espera, controle dos serviços de estética e acompanhamento pelo tutor.</div>
                    </div>
                </div>
                <div class="col-12 col-sm-6 col-lg-4" data-fade>
                    <div class="feature-card">
                        <div class="feature-icon-wrap"><i class="bi bi-box-seam-fill"></i></div>
                        <div class="feature-title">Controle de Estoque</div>
                        <div class="feature-desc">Entradas, saídas, alertas de mínimo e relatório de giro com curva ABC.</div>
                    </div>
                </div>
            </div>
            <div class="text-center mt-5" data-fade>
                <a href="{{ url('landing_recursos') }}" class="btn btn-primary-custom">
                    Ver todos os recursos <i class="bi bi-arrow-right"></i>
                </a>
            </div>
        </div>
    </section>

    {# ── CTA PLANOS (grid completo em /planos) ── #}
    <section class="how-section" id="planos" style="padding:80px 0;">
        <div class="container">
            <div class="row justify-content-center text-center">
                <div class="col-lg-7" data-fade>
                    <span class="section-tag">Planos</span>
                    <h2 class="section-title">Escolha o plano ideal para o seu negócio</h2>
                    <p style="color:var(--text-secondary);max-width:520px;margin:0 auto 2rem;">
                        Sem taxa de setup. Cancele quando quiser. Migre de plano a qualquer momento.
                    </p>
                    <a href="{{ url('landing_planos') }}" class="btn btn-primary-custom">
                        Ver Planos e Preços <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>
    </section>

    {# ── TEASER QUEM SOMOS (página completa em /quem-somos) ── #}
    <section class="about-section" id="quem-somos" style="padding:80px 0;">
        <div class="container">
            <div class="row align-items-center g-5">
                <div class="col-lg-7" data-fade>
                    <span class="section-tag">Quem Somos</span>
                    <h2 class="section-title">Paixão por tecnologia e cuidado animal</h2>
                    <p style="color:var(--text-secondary); margin-bottom: 1.5rem;">
                        Nascemos com a missão de modernizar o mercado pet brasileiro, oferecendo ferramentas
                        que eliminam a burocracia e permitem que você foque na saúde dos animais.
                    </p>
                    <a href="{{ url('landing_quem_somos') }}" class="btn btn-outline-custom">
                        Conheça nossa história <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
                <div class="col-lg-5" data-fade>
                    <div class="row g-3">
                        <div class="col-12 col-sm-6">
                            <div class="about-card">
                                <div class="about-icon"><i class="bi bi-shield-check"></i></div>
                                <div>
                                    <h5>Segurança</h5>
                                    <p>Dados criptografados.</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-sm-6">
                            <div class="about-card">
                                <div class="about-icon"><i class="bi bi-rocket-takeoff"></i></div>
                                <div>
                                    <h5>Inovação</h5>
                                    <p>Atualizações mensais.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="contact-section" id="contato">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-12 col-lg-10">
                    <div class="contact-form p-3 p-sm-4 p-md-5">
                        <div class="row g-5">
                            <div class="col-12 col-md-5">
                                <h3 class="mb-4">Vamos conversar?</h3>
                                <p class="text-secondary mb-5">Dúvidas sobre os planos ou precisa de uma demonstração
                                personalizada? Nossa equipe está pronta para ajudar.</p>
                                <div class="d-flex gap-3 mb-4 text-break">
                                    <div class="text-teal fs-4 flex-shrink-0"><i class="bi bi-envelope-at"></i></div>
                                    <div>
                                        <div class="fw-bold">E-mail</div>
                                        <div class="text-secondary">contato@systemhomepet.com.br</div>
                                    </div>
                                </div>
                                <div class="d-flex gap-3 mb-4 text-break">
                                    <div class="text-teal fs-4 flex-shrink-0"><i class="bi bi-whatsapp"></i></div>
                                    <div>
                                        <div class="fw-bold">WhatsApp</div>
                                        <div class="text-secondary"><a target="_blank" href="https://wa.me/553195318362?&text=Olá!+Tenho+interesse+em+conhecer+melhor+o+System+Home+Pet,+sistema+de+gestão+para+clínicas+veterinárias+e+pet+shops.+Gostaria+de+receber+mais+informações+sobre+as+funcionalidades,+planos+disponíveis,+valores+e+demais+recursos+oferecidos+pela+plataforma.&type=phone_number&app_absent=0">(31) 9531-8362</a></div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-12 col-md-7">

                                {% for label, messages in app.flashes %}
                                    {% for message in messages %}
                                        {% if label == 'contato_sucesso' %}
                                        <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
                                            <i class="bi bi-check-circle-fill me-2"></i>{{ message }}
                                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                                        </div>
                                        {% elseif label == 'contato_erro' %}
                                        <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
                                            <i class="bi bi-exclamation-triangle-fill me-2"></i>{{ message }}
                                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                                        </div>
                                        {% endif %}
                                    {% endfor %}
                                {% endfor %}

                                <form action="{{ path('landing_contato') }}" method="POST" id="formContato">
                                    <input type="hidden" name="_token" value="{{ csrf_token('contato') }}">
                                    <div class="mb-3">
                                        <label class="form-label-custom" for="contato_nome">Nome Completo</label>
                                        <input type="text" id="contato_nome" name="nome"
                                               class="form-control form-control-custom"
                                               placeholder="Ex: João Silva"
                                               required maxlength="150">
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label-custom" for="contato_email">E-mail</label>
                                        <input type="email" id="contato_email" name="email"
                                               class="form-control form-control-custom"
                                               placeholder="joao@seuempresa.com"
                                               required maxlength="200">
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label-custom" for="contato_mensagem">Mensagem</label>
                                        <textarea id="contato_mensagem" name="mensagem"
                                                  class="form-control form-control-custom" rows="4"
                                                  placeholder="Como podemos ajudar?"
                                                  required maxlength="2000"></textarea>
                                    </div>
                                    <button type="submit" id="btnEnviarContato"
                                            class="btn btn-primary-custom w-100 justify-content-center">
                                        <span id="btnTexto"><i class="bi bi-send me-2"></i>Enviar Mensagem</span>
                                        <span id="btnLoading" class="d-none">
                                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>Enviando...
                                        </span>
                                    </button>
                                </form>
                                <script>
                                document.getElementById('formContato').addEventListener('submit', function() {
                                    document.getElementById('btnTexto').classList.add('d-none');
                                    document.getElementById('btnLoading').classList.remove('d-none');
                                    document.getElementById('btnEnviarContato').disabled = true;
                                });
                                </script>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}