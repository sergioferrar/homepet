{% extends 'home/baseLanding.html.twig' %}
{% block body %}
    <section class="hero-section" id="inicio">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6">
                    <div class="hero-badge">
                        <i class="bi bi-lightning-charge-fill"></i>
                        Gestão completa em uma plataforma
                    </div>
                    <h1 class="hero-headline text-break">
                        O sistema completo para<br/>
                        <span class="line-teal">Pet Shops</span> &amp;<br/>
                        Clínicas Veterinárias
                    </h1>
                    <p class="hero-sub">
                        Centralize agendamentos, prontuários, financeiro, estoque e muito mais.
                        Uma solução moderna pensada para quem trabalha com o cuidado dos pets.
                    </p>
                    <div class="d-flex flex-wrap gap-3">
                        <a href="{{ url('landing_planos') }}" class="btn btn-primary-custom">
                            Começar Agora <i class="bi bi-arrow-right"></i>
                        </a>
                        <a href="#planos" class="btn btn-outline-custom">Ver Planos</a>
                    </div>
                    <div class="hero-stats row g-3 mt-4 row-cols-1 row-cols-sm-3">
                        <div class="col">
                            <div class="hero-stat-num">+2.400</div>
                            <div class="hero-stat-label">Estabelecimentos ativos</div>
                        </div>
                        <div class="col">
                            <div class="hero-stat-num">+18k</div>
                            <div class="hero-stat-label">Pets cadastrados</div>
                        </div>
                        <div class="col">
                            <div class="hero-stat-num">99.9%</div>
                            <div class="hero-stat-label">Uptime garantido</div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6 mt-5 mt-lg-0">
                    <div class="hero-mockup-wrap" style="overflow-x: auto; max-width: 100%;">
                        <div class="hero-mockup" style="min-width: 280px;">
                            <div class="mockup-bar">
                                <div class="mockup-dot mockup-dot-red"></div>
                                <div class="mockup-dot mockup-dot-yellow"></div>
                                <div class="mockup-dot mockup-dot-green"></div>
                                <div class="flex-grow-1 mx-3"
                                style="background:var(--border);height:18px;border-radius:6px;"></div>
                            </div>
                            <div class="mockup-body">
                                <div class="row g-3">
                                    <div class="col-12 col-md-3">
                                        <div class="dash-sidebar h-100 d-flex flex-row flex-md-column flex-wrap gap-2 justify-content-between justify-content-md-start">
                                            <div class="dash-nav-item active"><i class="bi bi-grid"></i> Painel</div>
                                            <div class="dash-nav-item"><i class="bi bi-calendar3"></i> Agenda</div>
                                            <div class="dash-nav-item"><i class="bi bi-people"></i> Clientes</div>
                                            <div class="dash-nav-item"><i class="bi bi-heart"></i> Pets</div>
                                            <div class="dash-nav-item"><i class="bi bi-box"></i> Estoque</div>
                                            <div class="dash-nav-item"><i class="bi bi-graph-up"></i> Relatórios</div>
                                        </div>
                                    </div>
                                    <div class="col-12 col-md-9">
                                        <div class="row g-2 mb-3 row-cols-1 row-cols-sm-3">
                                            <div class="col">
                                                <div class="dash-metric-card">
                                                    <div class="dash-metric-num">87</div>
                                                    <div class="dash-metric-label">Consultas hoje</div>
                                                    <div class="dash-bar">
                                                        <div class="dash-bar-fill" style="width:87%"></div>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col">
                                                <div class="dash-metric-card">
                                                    <div class="dash-metric-num">R$4,2k</div>
                                                    <div class="dash-metric-label">Faturamento</div>
                                                    <div class="dash-bar">
                                                        <div class="dash-bar-fill"
                                                        style="width:62%;background:var(--accent)"></div>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col">
                                                <div class="dash-metric-card">
                                                    <div class="dash-metric-num">34</div>
                                                    <div class="dash-metric-label">Novos clientes</div>
                                                    <div class="dash-bar">
                                                        <div class="dash-bar-fill"
                                                        style="width:45%;background:#7c6fcd"></div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <div style="background:var(--bg-subtle);border:1px solid var(--border);border-radius:10px;padding:1rem;">
                                            <div style="font-size:.72rem;color:var(--text-muted);font-weight:700;letter-spacing:.08em;text-transform:uppercase;margin-bottom:.8rem;">
                                                ATENDIMENTOS / SEMANA
                                            </div>
                                            <div style="display:flex;align-items:flex-end;gap:5px;height:60px;">
                                                <div style="flex:1;background:var(--teal-light);border-radius:4px 4px 0 0;height:40%"></div>
                                                <div style="flex:1;background:var(--teal-light);border-radius:4px 4px 0 0;height:65%"></div>
                                                <div style="flex:1;background:var(--teal);border-radius:4px 4px 0 0;height:55%"></div>
                                                <div style="flex:1;background:var(--teal-light);border-radius:4px 4px 0 0;height:80%"></div>
                                                <div style="flex:1;background:var(--teal-light);border-radius:4px 4px 0 0;height:50%"></div>
                                                <div style="flex:1;background:var(--teal);border-radius:4px 4px 0 0;height:90%"></div>
                                                <div style="flex:1;background:var(--teal-light);border-radius:4px 4px 0 0;height:70%"></div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="features-section" id="recursos">
        <div class="container">
            <div class="text-center mb-5" data-fade>
                <span class="section-tag">Recursos</span>
                <h2 class="section-title">Tudo que seu negócio precisa,<br/>em um só lugar</h2>
                <p style="color:var(--text-secondary);max-width:560px;margin:0 auto;">
                    Do atendimento ao controle financeiro, o System HomePro cobre cada etapa da operação do seu
                    estabelecimento.
                </p>
            </div>
            <div class="row g-4">
                <div class="col-12 col-sm-6 col-lg-4" data-fade>
                    <div class="feature-card">
                        <div class="feature-icon-wrap"><i class="bi bi-people-fill"></i></div>
                        <div class="feature-title">Gestão de Clientes e Pets</div>
                        <div class="feature-desc">Cadastro completo de tutores e seus animais com histórico de atendimentos
                            e informações detalhadas.
                        </div>
                    </div>
                </div>
                <div class="col-12 col-sm-6 col-lg-4" data-fade>
                    <div class="feature-card">
                        <div class="feature-icon-wrap"><i class="bi bi-clipboard2-pulse-fill"></i></div>
                        <div class="feature-title">Prontuário Veterinário</div>
                        <div class="feature-desc">Registros clínicos completos, anotações, diagnósticos e prescrições
                            organizados por pet e data.
                        </div>
                    </div>
                </div>
                <div class="col-12 col-sm-6 col-lg-4" data-fade>
                    <div class="feature-card">
                        <div class="feature-icon-wrap"><i class="bi bi-shield-plus-fill"></i></div>
                        <div class="feature-title">Controle de Vacinas</div>
                        <div class="feature-desc">Calendário vacinal automatizado com lembretes para tutores e visão
                            completa do histórico imunológico.
                        </div>
                    </div>
                </div>
                <div class="col-12 col-sm-6 col-lg-4" data-fade>
                    <div class="feature-card">
                        <div class="feature-icon-wrap"><i class="bi bi-currency-dollar"></i></div>
                        <div class="feature-title">Controle Financeiro</div>
                        <div class="feature-desc">Fluxo de caixa, contas a pagar/receber, DRE simplificado e conciliação
                            financeira em tempo real.
                        </div>
                    </div>
                </div>
                <div class="col-12 col-sm-6 col-lg-4" data-fade>
                    <div class="feature-card">
                        <div class="feature-icon-wrap"><i class="bi bi-calendar3-week-fill"></i></div>
                        <div class="feature-title">Agenda de Consultas</div>
                        <div class="feature-desc">Agendamento online integrado, gestão de horários por veterinário e
                            confirmação automática por e-mail.
                        </div>
                    </div>
                </div>
                <div class="col-12 col-sm-6 col-lg-4" data-fade>
                    <div class="feature-card">
                        <div class="feature-icon-wrap"><i class="bi bi-scissors"></i></div>
                        <div class="feature-title">Banho &amp; Tosa</div>
                        <div class="feature-desc">Controle completo de serviços de estética pet, fila de espera e
                            acompanhamento em tempo real pelo tutor.
                        </div>
                    </div>
                </div>
                <div class="col-12 col-sm-6 col-lg-4" data-fade>
                    <div class="feature-card">
                        <div class="feature-icon-wrap"><i class="bi bi-box-seam-fill"></i></div>
                        <div class="feature-title">Controle de Estoque</div>
                        <div class="feature-desc">Entradas, saídas, alertas de estoque mínimo e relatório de giro de
                            produtos com curva ABC.
                        </div>
                    </div>
                </div>
                <div class="col-12 col-sm-6 col-lg-4" data-fade>
                    <div class="feature-card">
                        <div class="feature-icon-wrap"><i class="bi bi-graph-up-arrow"></i></div>
                        <div class="feature-title">Relatórios Gerenciais</div>
                        <div class="feature-desc">Dashboards personalizáveis, exportação em PDF/Excel e insights para tomada
                            de decisão estratégica.
                        </div>
                    </div>
                </div>
                <div class="col-12 col-sm-6 col-lg-4" data-fade>
                    <div class="feature-card">
                        <div class="feature-icon-wrap"><i class="bi bi-person-badge-fill"></i></div>
                        <div class="feature-title">Usuários por Nível de Acesso</div>
                        <div class="feature-desc">Admin, veterinário, atendente, caixa e outros perfis com permissões
                            granulares para máxima segurança.
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="how-section" id="como-funciona">
        <div class="container">
            <div class="row justify-content-center mb-5">
                <div class="col-lg-6 text-center" data-fade>
                    <span class="section-tag">Como Funciona</span>
                    <h2 class="section-title">Pronto para usar em<br/>menos de 5 minutos</h2>
                    <p style="color:var(--text-secondary);">Nosso processo de onboarding foi projetado para ser simples,
                    rápido e seguro.</p>
                </div>
            </div>
            <div class="row justify-content-center">
                <div class="col-12 col-lg-8">
                    <div class="timeline-wrap ps-2">
                        <div class="timeline-line"></div>
                        <div class="timeline-step" data-fade>
                            <div class="step-number">1</div>
                            <div class="step-content">
                                <h4>Cadastro do Estabelecimento</h4>
                                <p>O responsável acessa a página de cadastro e informa os dados do pet shop ou clínica. O
                                processo leva menos de 2 minutos.</p>
                            </div>
                        </div>
                        <div class="timeline-step" data-fade>
                            <div class="step-number">2</div>
                            <div class="step-content">
                                <h4>Confirmação por E-mail</h4>
                                <p>Um e-mail automático é enviado ao endereço cadastrado com um link de ativação exclusivo e
                                com validade de 24 horas.</p>
                            </div>
                        </div>
                        <div class="timeline-step" data-fade>
                            <div class="step-number">3</div>
                            <div class="step-content">
                                <h4>Criação do Usuário Administrador</h4>
                                <p>Ao clicar no link, o responsável cria o usuário ADMIN do estabelecimento — com acesso
                                total ao sistema e configurações.</p>
                            </div>
                        </div>
                        <div class="timeline-step" data-fade>
                            <div class="step-number">4</div>
                            <div class="step-content">
                                <h4>Cadastro da Equipe</h4>
                                <p>O administrador cadastra todos os colaboradores: <strong>operador de caixa, banho &amp;
                                tosa, veterinários, atendentes</strong> e outros com permissões específicas.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="plans-section" id="planos">
        <div class="container">
            <div class="text-center mb-5" data-fade>
                <span class="section-tag">Planos</span>
                <h2 class="section-title">Escolha o plano ideal<br/>para o seu negócio</h2>
                <p style="color:var(--text-secondary);max-width:500px;margin:0 auto;">
                    Sem taxa de setup. Cancele quando quiser. Migre de plano a qualquer momento.
                </p>
            </div>
            <div class="row g-4 justify-content-center">
                {% for plano in planos %}
                    {% set isPopular = plano.trial == 1 or plano.trial == '1' %}
                    <div class="col-12 col-md-6 col-lg-4 visible" data-fade="">
                        <div class="plan-card {% if isPopular %}featured{% endif %}">
                            {% if isPopular %}
                                <div class="plan-badge">Mais Popular</div>
                            {% endif %}
                            <div class="plan-name">{{ plano.titulo }}</div>
                            <div class="plan-price text-break">{{ plano.valor|formataValorEmRealLanding|raw }}</div>
                            <div class="plan-period">por mês</div>
                            <div class="plan-divider"></div>
                            {{ plano.descricao|listaPlano|raw }}
                            <a href="{{ url('landing_cadastro', {'planoId': plano.id}) }}"
                            class="btn btn-outline-custom w-100 mt-4">Selecionar Plano</a>
                        </div>
                    </div>
                {% else %}
                    <div class="col-12 text-center py-5">
                        <p class="text-muted">Planos em breve disponíveis.</p>
                    </div>
                {% endfor %}
            </div>
        </div>
    </section>

    <section class="about-section" id="quem-somos">
        <div class="container">
            <div class="row align-items-center g-5">
                <div class="col-lg-6" data-fade>
                    <span class="section-tag">Quem Somos</span>
                    <h2 class="section-title">Paixão por tecnologia e cuidado animal</h2>
                    <p style="color:var(--text-secondary); margin-bottom: 2rem;">
                        Nascemos com a missão de modernizar o mercado pet brasileiro, oferecendo ferramentas que eliminam a
                        burocracia e permitem que você foque no que realmente importa: a saúde dos animais.
                    </p>
                    <div class="row g-3">
                        <div class="col-12 col-sm-6">
                            <div class="about-card">
                                <div class="about-icon"><i class="bi bi-shield-check"></i></div>
                                <div>
                                    <h5>Segurança</h5>
                                    <p>Dados criptografados.</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-sm-6">
                            <div class="about-card">
                                <div class="about-icon"><i class="bi bi-rocket-takeoff"></i></div>
                                <div>
                                    <h5>Inovação</h5>
                                    <p>Atualizações mensais.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6" data-fade>
                    <div style="background: var(--teal-light); border-radius: 24px; padding: 2rem; border: 1px solid var(--teal);" class="p-3 p-sm-4 p-md-5">
                        <h4 class="mb-3">Nossa Visão</h4>
                        <p class="text-secondary">Ser o sistema de gestão pet líder na América Latina, conectando tutores,
                        profissionais e estabelecimentos em um ecossistema digital inteligente e humano.</p>
                        <div class="divider-line"></div>
                        <div class="d-flex align-items-center gap-3 flex-wrap">
                            <div style="width: 48px; height: 48px; border-radius: 50%; background: var(--teal); display: flex; align-items: center; justify-content: center; color: white;" class="flex-shrink-0">
                                <i class="bi bi-quote"></i>
                            </div>
                            <div>
                                <div class="fw-bold">Equipe System Home Pet</div>
                                <div class="small text-muted">Desde 2018</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="contact-section" id="contato">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-12 col-lg-10">
                    <div class="contact-form p-3 p-sm-4 p-md-5">
                        <div class="row g-5">
                            <div class="col-12 col-md-5">
                                <h3 class="mb-4">Vamos conversar?</h3>
                                <p class="text-secondary mb-5">Dúvidas sobre os planos ou precisa de uma demonstração
                                personalizada? Nossa equipe está pronta para ajudar.</p>
                                <div class="d-flex gap-3 mb-4 text-break">
                                    <div class="text-teal fs-4 flex-shrink-0"><i class="bi bi-envelope-at"></i></div>
                                    <div>
                                        <div class="fw-bold">E-mail</div>
                                        <div class="text-secondary">contato@systemhomepet.com.br</div>
                                    </div>
                                </div>
                                <div class="d-flex gap-3 mb-4 text-break">
                                    <div class="text-teal fs-4 flex-shrink-0"><i class="bi bi-whatsapp"></i></div>
                                    <div>
                                        <div class="fw-bold">WhatsApp</div>
                                        <div class="text-secondary"><a target="_blank" href="https://wa.me/553195318362?&text=Olá!+Tenho+interesse+em+conhecer+melhor+o+System+Home+Pet,+sistema+de+gestão+para+clínicas+veterinárias+e+pet+shops.+Gostaria+de+receber+mais+informações+sobre+as+funcionalidades,+planos+disponíveis,+valores+e+demais+recursos+oferecidos+pela+plataforma.&type=phone_number&app_absent=0">(31) 9531-8362</a></div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-12 col-md-7">
                                <form>
                                    <div class="mb-3">
                                        <label class="form-label-custom">Nome Completo</label>
                                        <input type="text" class="form-control form-control-custom"
                                        placeholder="Ex: João Silva">
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label-custom">E-mail Corporativo</label>
                                        <input type="email" class="form-control form-control-custom"
                                        placeholder="joao@seuempresa.com">
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label-custom">Mensagem</label>
                                        <textarea class="form-control form-control-custom" rows="4"
                                        placeholder="Como podemos ajudar?"></textarea>
                                    </div>
                                    <button type="submit" class="btn btn-primary-custom w-100 justify-content-center">Enviar Mensagem</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}