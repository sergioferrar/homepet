{% extends 'home/baseLanding.html.twig' %}

{% block title %}Termos de Uso{% endblock %}
{% block meta_description %}Termos de Uso do System Home Pet: condições de contratação e utilização do sistema de gestão para pet shops e clínicas veterinárias.{% endblock %}
{% block meta_keywords %}termos de uso, condições de contratação, system home pet{% endblock %}
{% block stylesheets %}
    <style>
        
        :root {
            --brand: #5d57f4;
            --brand-dark: #4a45c7;
            --text: #0f172a;
            --muted: #64748b;
            --bg: #f8fafc;
            --border: #e2e8f0;
        }

        .page-header {
            background: linear-gradient(135deg, #1e293b 0%, #334155 100%);
            color: #fff; padding: 4rem 0 2.5rem;
        }
        .page-header .badge-termos {
            background: rgba(255,255,255,.12); border: 1px solid rgba(255,255,255,.25);
            color: #fff; font-weight: 500; font-size: .78rem; padding: .35rem .75rem;
            border-radius: 2rem; display: inline-block; margin-bottom: 1rem;
        }
        .content-card {
            background: #fff; border-radius: 1rem; box-shadow: 0 2px 16px rgba(0,0,0,.07);
            padding: 2.5rem; margin-top: -1.5rem; margin-bottom: 3rem;
        }
        .content-card h1, .content-card h2, .content-card h3 { color: #1e293b; margin-top: 1.5rem; }
        .content-card p, .content-card li { line-height: 1.8; color: #334155; }
        .dpo-card {
            background: #f0fdf4; border: 1px solid #bbf7d0;
            border-radius: .75rem; padding: 1.25rem 1.5rem;
        }
        .navbar-pub { background: #fff; border-bottom: 1px solid var(--border); padding: .75rem 0; }
        .empty-state { color: var(--muted); text-align: center; padding: 4rem 2rem; }
    </style>
{% endblock %}
{% block body %}


<section class="hero-section" id="inicio">
{# Hero #}
<div class="page-header">
    <div class="container">
        <span class="badge-termos"><i class="bi bi-file-earmark-text me-1"></i>Condições de uso da plataforma</span>
        <h1 class="fw-bold mb-2 text-white" style="font-size:2rem;">Termos de Uso</h1>
        <p class="mb-0" style="color:rgba(255,255,255,.75);max-width:600px;">
            Ao utilizar o System Home Pet, você concorda com as condições descritas neste documento.
            Leia com atenção antes de usar a plataforma.
        </p>
    </div>
</div>

{# Conteúdo #}
<div class="container">
    <div class="content-card">

        {% if conteudo %}
            <div class="lgpd-content">{{ conteudo|raw }}</div>
        {% else %}
            <div class="empty-state">
                <i class="bi bi-file-earmark-text" style="font-size:3rem;color:#cbd5e1;"></i>
                <p class="mt-3">Os Termos de Uso ainda não foram cadastrados.<br>
                Acesse as configurações do sistema para adicionar o conteúdo.</p>
            </div>
        {% endif %}

        {# Bloco DPO #}
        {% if dpo_nome or dpo_email %}
        <hr class="my-4">
        <div class="dpo-card">
            <h6 class="fw-bold mb-1" style="color:#15803d;">
                <i class="bi bi-person-badge me-1"></i>Dúvidas sobre privacidade e dados?
            </h6>
            <p class="mb-0 small" style="color:#334155;">
                Entre em contato com nosso Encarregado de Dados (DPO):
                {% if dpo_nome %}<strong>{{ dpo_nome }}</strong>{% endif %}
                {% if dpo_email %}
                    — <a href="mailto:{{ dpo_email }}" style="color:#15803d;">{{ dpo_email }}</a>
                {% endif %}
            </p>
        </div>
        {% endif %}

        <hr class="my-4">
        <div class="d-flex flex-wrap gap-3 small" style="color:var(--muted);">
            <a href="{{ path('landing_home') }}" style="color:var(--brand);text-decoration:none;">
                <i class="bi bi-arrow-left me-1"></i>Voltar ao início
            </a>
            <a href="{{ path('landing_politica_privacidade') }}" style="color:var(--brand);text-decoration:none;">
                <i class="bi bi-shield-lock me-1"></i>Política de Privacidade
            </a>
        </div>
    </div>
</div>
</section>
{% endblock %}