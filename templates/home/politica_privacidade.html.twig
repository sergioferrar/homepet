{% extends 'home/baseLanding.html.twig' %}
{% block stylesheets %}
     <style>
        :root {
            --brand: #5d57f4;
            --brand-dark: #4a45c7;
            --text: #0f172a;
            --muted: #64748b;
            --bg: #f8fafc;
            --border: #e2e8f0;
        }
        body { font-family: 'Roboto', sans-serif; background: var(--bg); color: var(--text); }
        .page-header {
            background: linear-gradient(135deg, var(--brand) 0%, var(--brand-dark) 100%);
            color: #fff; padding: 4rem 0 2.5rem;
        }
        .page-header .badge-lgpd {
            background: rgba(255,255,255,.15); border: 1px solid rgba(255,255,255,.3);
            color: #fff; font-weight: 500; font-size: .78rem; padding: .35rem .75rem;
            border-radius: 2rem; display: inline-block; margin-bottom: 1rem;
        }
        .content-card {
            background: #fff; border-radius: 1rem; box-shadow: 0 2px 16px rgba(0,0,0,.07);
            padding: 2.5rem; margin-top: -1.5rem; margin-bottom: 3rem;
        }
        .content-card h1, .content-card h2, .content-card h3 {
            color: var(--brand); margin-top: 1.5rem;
        }
        .content-card p, .content-card li { line-height: 1.8; color: #334155; }
        .dpo-card {
            background: #efeeff; border: 1px solid #c7c4f5;
            border-radius: .75rem; padding: 1.25rem 1.5rem;
        }
        .navbar-pub { background: #fff; border-bottom: 1px solid var(--border); padding: .75rem 0; }
        .empty-state { color: var(--muted); text-align: center; padding: 4rem 2rem; }
        footer { background: #0f172a; color: #94a3b8; padding: 2rem 0; font-size: .85rem; }
        footer a { color: #93c5fd; text-decoration: none; }
    </style>
{% endblock %}
{% block body %}
<section class="hero-section" id="inicio">
    <div class="page-header">
    <div class="container">
        <span class="badge-lgpd"><i class="bi bi-shield-lock me-1"></i>LGPD — Lei 13.709/2018</span>
        <h1 class="fw-bold mb-2 text-white" style="font-size:2rem;">Política de Privacidade</h1>
        <p class="mb-0" style="color:rgba(255,255,255,.8);max-width:600px;">
            Saiba como coletamos, utilizamos e protegemos seus dados pessoais em conformidade com a Lei Geral de Proteção de Dados.
        </p>
    </div>
</div>

{# Conteúdo #}
<div class="container">
    <div class="content-card">

        {% if conteudo %}
            <div class="lgpd-content">{{ conteudo|raw }}</div>
        {% else %}
            <div class="empty-state">
                <i class="bi bi-file-earmark-lock2" style="font-size:3rem;color:#c7c4f5;"></i>
                <p class="mt-3">A Política de Privacidade ainda não foi cadastrada.<br>
                Acesse as configurações do sistema para adicionar o conteúdo.</p>
            </div>
        {% endif %}

        {# Bloco DPO — exibido quando há informação cadastrada #}
        {% if dpo_nome or dpo_email %}
        <hr class="my-4">
        <div class="dpo-card">
            <h6 class="fw-bold mb-1" style="color:var(--brand);">
                <i class="bi bi-person-badge me-1"></i>Encarregado de Dados (DPO)
            </h6>
            <p class="mb-0 small" style="color:#334155;">
                Para exercer seus direitos como titular (acesso, correção, exclusão, portabilidade),
                entre em contato com nosso DPO:
                {% if dpo_nome %}<strong>{{ dpo_nome }}</strong>{% endif %}
                {% if dpo_email %}
                    — <a href="mailto:{{ dpo_email }}" style="color:var(--brand);">{{ dpo_email }}</a>
                {% endif %}
            </p>
        </div>
        {% endif %}

        <hr class="my-4">
        <div class="d-flex flex-wrap gap-3 small" style="color:var(--muted);">
            <a href="{{ path('landing_home') }}" style="color:var(--brand);text-decoration:none;">
                <i class="bi bi-arrow-left me-1"></i>Voltar ao início
            </a>
            <a href="{{ path('landing_termos_uso') }}" style="color:var(--brand);text-decoration:none;">
                <i class="bi bi-file-earmark-text me-1"></i>Termos de Uso
            </a>
        </div>
    </div>
</div>
</section>
{# Hero #}

{% endblock %}